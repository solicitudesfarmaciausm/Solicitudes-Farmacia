# Backend
SUPABASE_URL=
SUPABASE_KEY=

# Supabase Storage (attachments)
# If ruta_archivo is a Storage path (e.g. "bucket/path/to/file" or "path/to/file"),
# these variables enable generating signed download URLs.
SUPABASE_STORAGE_BUCKET=
SUPABASE_SIGNED_URL_EXPIRES_IN=3600

# JWT for auth (login)
JWT_SECRET=

# TEMP: Require Bearer token on archivos endpoints.
# Set to 1 to protect /api/solicitudes/:id/archivos and /api/solicitudes/:id/archivos/:id_archivo.
# Default is 0 to allow development without token.
REQUIRE_AUTH_FOR_ARCHIVOS=0
